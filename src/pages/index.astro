---
import BlogLayout from '../layouts/BlogLayout.astro'
import Banner from '../components/Banner.astro'
import PostCard from '../components/PostCard.astro'
import { getCollection } from 'astro:content'
import { getDerivedFromPosts } from '../utils/derived-collections'

const posts = await getCollection('post', ({ data }) => data.published)
const sorted = [...posts].sort((a, b) => b.data.created_timestamp - a.data.created_timestamp)
const { categories, tags, postCategories, postTags } = getDerivedFromPosts(sorted)
const categoryCounts = Object.fromEntries(categories.map((c) => [c.id, postCategories.filter((pc) => pc.categoryId === c.id).length]))
const tagCounts = Object.fromEntries(tags.map((t) => [t.id, postTags.filter((pt) => pt.tagId === t.id).length]))
const menu = (await getCollection('menu')).map((e) => ({ title: e.data.title, url: e.data.url, target: e.data.target }))
const [setting] = await getCollection('setting')
const authors = await getCollection('author')
const defaultAuthor = authors.find((a) => a.data.isDefault) ?? authors[0]
const siteName = setting?.data.siteSetting?.siteName ?? '博客'
const recordInfo = setting?.data.recordSettings ? { ...setting.data.recordSettings } : undefined
---
<BlogLayout
  title={siteName}
  siteName={siteName}
  menu={menu}
  categories={categories}
  tags={tags}
  categoryCounts={categoryCounts}
  tagCounts={tagCounts}
  author={defaultAuthor ? { title: defaultAuthor.data.title, excerpt: defaultAuthor.data.excerpt, url: defaultAuthor.data.url } : undefined}
  recordInfo={recordInfo}
>
  <Banner title={siteName} subtitle={setting?.data.siteSetting?.siteDescription} />
  <div class="intro-bubble animate-in animate-in-delay-1">
    <p class="m-0 code-label">$ count: <strong style="color:var(--accent)">{sorted.length}</strong> posts --top={sorted.length}</p>
    <p class="m-0 mt-1 code-label">[INFO] 共 {sorted.length} 篇，点击标题进入文章</p>
  </div>
  <section class="space-y-5">
    <h2 class="section-title animate-in animate-in-delay-2">
      <span class="section-prompt">#</span> export 最新文章
    </h2>
    {sorted.length === 0 ? (
      <div class="section-card p-8 text-center animate-in animate-in-delay-3">
        <p class="m-0" style="color:var(--text-muted);font-family:var(--font-mono)">// no posts yet</p>
      </div>
    ) : (
      <ul class="post-list terminal-list">
        {sorted.map((entry) => (
          <li>
            <PostCard
              title={entry.data.title}
              url={entry.data.url}
              excerpt={entry.data.excerpt}
              pubDate={entry.data.created_timestamp}
              categories={entry.data.categories}
              tags={entry.data.tags}
            />
          </li>
        ))}
      </ul>
    )}
  </section>
</BlogLayout>
