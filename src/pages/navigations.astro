---
import BlogLayout from '../layouts/BlogLayout.astro'
import Banner from '../components/Banner.astro'
import navData from '../content/json/navigationWebsiteData.json'

const navCategories = (navData as { categories: Array<{ id: string; name: string; description?: string; websites: Array<{ id: string; title: string; description?: string; url: string; icon?: string; tags?: string[] }> }> }).categories
const totalSites = navCategories.reduce((sum, c) => sum + c.websites.length, 0)
---
<BlogLayout title="类库导航">
  <Banner title="类库导航" subtitle="精选前端文档与工具导航" />
  <div class="intro-bubble animate-in animate-in-delay-1">
    <p class="m-0 code-label">共 <strong>{totalSites}</strong> 个站点</p>
  </div>
  <section class="space-y-8">
    <h2 class="section-title animate-in animate-in-delay-2">按分类浏览</h2>
    <p class="code-label mb-6">点击站点将在新窗口打开</p>
    {navCategories.map((cat, i) => (
      <div class="section-card p-5 sm:p-6 animate-in nav-category-group" id={`nav-${cat.id}`} style={`animation-delay: ${0.1 + i * 0.05}s`}>
        <h2 class="section-title">{cat.name}</h2>
        {cat.description && <p class="code-label mb-1">{cat.description}</p>}
        <p class="code-label mb-3">{cat.websites.length} 个站点</p>
        <ul class="post-list terminal-list">
          {cat.websites.map((site) => (
            <li>
              <a
                href={site.url}
                target="_blank"
                rel="noopener noreferrer"
                class="terminal-item block transition-colors hover:text-(--accent)"
              >
                <div class="post-card-link">
                  <span class="post-card-link-title">{site.title}</span>
                  {site.description && <span class="meta-desc"> · {site.description}</span>}
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</BlogLayout>
