---
import BlogLayout from '../layouts/BlogLayout.astro'
import Banner from '../components/Banner.astro'
import Comment from '../components/client/Comment.tsx'
import { getCollection, render } from 'astro:content'

const pages = await getCollection('page', ({ data }) => data.published)
const aboutEntry = pages.find((p) => p.data.alias === 'about' || p.data.title?.toLowerCase() === 'about')
if (!aboutEntry) return Astro.redirect('/')
const { Content } = await render(aboutEntry)
---
<BlogLayout title="关于">
  <Banner title="关于" subtitle={aboutEntry.data.excerpt || ''} />
  <div class="intro-bubble animate-in animate-in-delay-1">
    <p class="m-0 code-label">$ cat about.md</p>
  </div>
  <article class="section-card p-6 md:p-10 prose max-w-none prose-headings:font-semibold prose-img:rounded-xl markdown-body animate-in animate-in-delay-2">
    <Content />
    <Comment client:load postId="/about" />
  </article>
</BlogLayout>
