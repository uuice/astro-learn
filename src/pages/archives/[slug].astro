---
import BlogLayout from '../../layouts/BlogLayout.astro'
import { getCollection, render } from 'astro:content'
import { getDerivedFromPosts } from '../../utils/derived-collections'

export async function getStaticPaths() {
  const posts = await getCollection('post', ({ data }) => data.published)
  return posts.map((p) => ({ params: { slug: p.data.url.replace(/^\/archives\/?/, '') } }))
}

const slug = Astro.params.slug ?? ''
const posts = await getCollection('post', ({ data }) => data.published)
const post = posts.find((p) => p.data.url.replace(/^\/archives\/?/, '') === slug)
if (!post) return Astro.redirect('/')
const { Content, headings = [] } = await render(post)
const { categories, tags, postCategories, postTags } = getDerivedFromPosts(posts)
const categoryCounts = Object.fromEntries(categories.map((c) => [c.id, postCategories.filter((pc) => pc.categoryId === c.id).length]))
const tagCounts = Object.fromEntries(tags.map((t) => [t.id, postTags.filter((pt) => pt.tagId === t.id).length]))
const menu = (await getCollection('menu')).map((e) => ({ title: e.data.title, url: e.data.url, target: e.data.target }))
const [setting] = await getCollection('setting')
const authors = await getCollection('author')
const defaultAuthor = authors.find((a) => a.data.isDefault) ?? authors[0]
const siteName = setting?.data.siteSetting?.siteName ?? '博客'
const recordInfo = setting?.data.recordSettings ? { ...setting.data.recordSettings } : undefined
const tocList = headings.filter((h) => h.depth >= 2 && h.depth <= 3)
const postSlug = post.data.title.replace(/\s+/g, '-').replace(/[^\w\u4e00-\u9fa5-]/g, '').toLowerCase() || 'post'
const metaFrom = post.data.categories?.length ? ` from "${post.data.categories.join(', ')}"` : ''
const dateStr = new Date(post.data.created_timestamp).toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })
---
<BlogLayout
  title={post.data.title}
  siteName={siteName}
  menu={menu}
  categories={categories}
  tags={tags}
  categoryCounts={categoryCounts}
  tagCounts={tagCounts}
  author={defaultAuthor ? { title: defaultAuthor.data.title, excerpt: defaultAuthor.data.excerpt, url: defaultAuthor.data.url } : undefined}
  recordInfo={recordInfo}
>
  <p class="mb-4">
    <a href="/archives" class="inline-flex items-center gap-1 px-2 py-1 rounded text-sm font-medium transition-colors hover:bg-(--card-border)" style="color:var(--accent);font-family:var(--font-mono)">$ cd ..</a>
  </p>
  <article class="section-card overflow-hidden">
    <header class="px-6 md:px-10 pt-6 pb-5 border-b" style="border-color:var(--card-border)">
      <p class="doc-detail-header-export">### export <span class="export-name">{postSlug}</span></p>
      <h1 class="font-bold mb-2" style="color:var(--text);font-size:var(--text-xl);font-family:var(--font-mono);margin:0">{post.data.title}</h1>
      <p class="doc-detail-meta">{dateStr}{metaFrom}{post.data.tags?.length ? ' ' + post.data.tags.join(' ') : ''}</p>
      <p class="doc-detail-meta mt-1">// 文档</p>
    </header>
    <div class="p-6 md:p-10 flex flex-col lg:flex-row gap-8">
      {tocList.length > 0 && (
        <nav class="lg:w-48 shrink-0 order-2 lg:order-1" aria-label="目录">
          <div class="doc-detail-toc sticky top-24">
            <div class="doc-detail-toc-title"># &gt; 目录</div>
            <ul>
              {tocList.map((h) => (
                <li>
                  <a href={`#${h.slug}`} class={h.depth === 3 ? 'toc-depth-3' : ''}>
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </nav>
      )}
      <div class="flex-1 min-w-0 order-1 lg:order-2 doc-detail-body prose max-w-none prose-headings:font-semibold prose-img:rounded-xl markdown-body" style="font-size:var(--text-base)">
        <Content />
      </div>
    </div>
  </article>
</BlogLayout>
