---
import BlogLayout from '../../layouts/BlogLayout.astro'
import ArticleCopyright from '../../components/ArticleCopyright.astro'
import Comment from '../../components/client/Comment.tsx'
import { getCollection, render } from 'astro:content'

const slug = Astro.params.slug ?? ''
const posts = await getCollection('post', ({ data }) => data.published)
const post = posts.find((p) => p.data.url.replace(/^\/archives\/?/, '') === slug)
if (!post) return Astro.redirect('/')
const { Content, headings = [] } = await render(post)
const tocList = headings.filter((h) => h.depth >= 2 && h.depth <= 3)
const postSlug = post.data.title.replace(/\s+/g, '-').replace(/[^\w\u4e00-\u9fa5-]/g, '').toLowerCase() || 'post'
const metaFrom = post.data.categories?.length ? ` from "${post.data.categories.join(', ')}"` : ''
const dateStr = new Date(post.data.created_timestamp).toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })
---
<BlogLayout title={post.data.title}>
  <p class="mb-4 animate-in animate-in-delay-1">
    <a href="/archives" class="inline-flex items-center gap-1 px-2 py-1 rounded text-sm font-medium transition-colors hover:bg-(--card-border)" style="color:var(--accent);font-family:var(--font-mono)">$ cd ..</a>
  </p>
  <article class="section-card overflow-hidden animate-in animate-in-delay-2">
    <header class="px-6 md:px-10 pt-6 pb-5 border-b" style="border-color:var(--card-border)">
      <p class="doc-detail-header-export">### export <span class="export-name">{postSlug}</span></p>
      <h1 class="font-bold mb-2" style="color:var(--text);font-size:var(--text-xl);font-family:var(--font-mono);margin:0">{post.data.title}</h1>
      <p class="doc-detail-meta flex flex-wrap items-center gap-x-4 gap-y-1">
        <span><span class="doc-detail-meta-label" aria-label="日期">@</span> {dateStr}</span>
        {post.data.categories?.length ? (
          <span><span class="doc-detail-meta-label" aria-label="分类">▸</span> {post.data.categories.join(', ')}</span>
        ) : null}
        {post.data.tags?.length ? (
          <span class="flex items-center gap-1.5 flex-wrap">
            <span class="doc-detail-meta-label" aria-label="标签">#</span>
            {post.data.tags.map((t) => (
              <span class="doc-detail-meta-tag">{t}</span>
            ))}
          </span>
        ) : null}
      </p>
      <p class="doc-detail-meta mt-1">// 文档</p>
    </header>
    <div class="p-6 md:p-10 flex flex-col lg:flex-row gap-8">
      {tocList.length > 0 && (
        <nav class="lg:w-48 shrink-0 order-2 lg:order-1 animate-in animate-in-delay-2" aria-label="目录">
          <div class="doc-detail-toc doc-detail-toc-animated sticky top-24">
            <div class="doc-detail-toc-title"># &gt; 目录</div>
            <ul>
              {tocList.map((h, i) => (
                <li class="doc-detail-toc-item" style={`animation-delay: ${0.08 + i * 0.04}s`}>
                  <a href={`#${h.slug}`} class={h.depth === 3 ? 'toc-depth-3' : ''}>
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </nav>
      )}
      <div class="flex-1 min-w-0 order-1 lg:order-2 doc-detail-body prose max-w-none prose-headings:font-semibold prose-img:rounded-xl markdown-body" style="font-size:var(--text-sm)">
        <Content />
        <ArticleCopyright articleUrl={post.data.url} publishDate={dateStr} />
        <Comment client:load postId={post.data.url} />
      </div>
    </div>
  </article>
</BlogLayout>
