---
import BlogLayout from '../../layouts/BlogLayout.astro'
import Banner from '../../components/Banner.astro'
import { getCollection } from 'astro:content'

const [setting] = await getCollection('setting')
const siteName = setting?.data.siteSetting?.siteName ?? '博客'
const games = [
  {
    title: '算术挑战',
    description: 'PixiJS · 口算练习',
    url: '/games/math',
  },
]
---
<BlogLayout title={`小游戏 - ${siteName}`}>
  <Banner title="小游戏" subtitle="轻量互动 · 学习与摸鱼皆可；后续会陆续增加更多条目" />
  <div class="intro-bubble animate-in animate-in-delay-1">
    <p class="m-0 code-label">已上线 <strong>{games.length}</strong> 个小游戏</p>
  </div>
  <section class="space-y-5 animate-in animate-in-delay-2">
    <h2 class="section-title">游戏列表</h2>
    <div class="section-card p-0 overflow-hidden">
      <ul class="terminal-list m-0">
        {games.map((game) => (
          <li>
            <a
              href={game.url}
              class="group flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 py-4 px-4 border-b transition-colors hover:bg-(--card-border)/30"
              style="border-color:var(--card-border)"
            >
              <span>
                <span class="font-semibold" style="font-family:var(--font-mono);color:var(--text)">{game.title}</span>
                <span class="code-label ml-2">{game.description}</span>
              </span>
              <span class="code-label shrink-0">进入 →</span>
            </a>
          </li>
        ))}
        <li class="py-4 px-4 code-label">
          <span class="opacity-80">更多小游戏即将上线…</span>
        </li>
      </ul>
    </div>
  </section>
</BlogLayout>
