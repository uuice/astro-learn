---
import BlogLayout from '../../layouts/BlogLayout.astro'
import Banner from '../../components/Banner.astro'
import PostCard from '../../components/PostCard.astro'
import { getCollection } from 'astro:content'
import { getDerivedFromPosts } from '../../utils/derived-collections'

const { slug } = Astro.params
const posts = await getCollection('post', ({ data }) => data.published)
const { categories, postCategories, postTags } = getDerivedFromPosts(posts)
const category = categories.find((c) => c.url.replace(/^\/categories\//, '') === slug)
if (!category) return Astro.redirect('/')
const postIds = new Set(postCategories.filter((pc) => pc.categoryId === category.id).map((pc) => pc.postId))
const list = posts.filter((p) => postIds.has(p.id)).sort((a, b) => b.data.created_timestamp - a.data.created_timestamp)
---
<BlogLayout title={`分类: ${category.title}`}>
  <Banner title={`分类: ${category.title}`} subtitle={category.description || `共 ${list.length} 篇`} />
  <div class="intro-bubble animate-in animate-in-delay-1">
    <p class="m-0 code-label"><span class="sym sym-prompt">$</span> count: <strong>{list.length}</strong> <span class="sym sym-flag">--top={list.length}</span></p>
    <p class="m-0 code-label"><span class="sym sym-info">[INFO]</span> 该分类下共 {list.length} 篇文章</p>
  </div>
  <section class="space-y-5">
    <h2 class="section-title animate-in animate-in-delay-2"><span class="section-prompt">##</span> export {category.title}</h2>
    <p class="code-label mb-3"><span class="sym sym-comment">//</span> {list.length} posts</p>
    {list.length === 0 ? (
      <div class="section-card p-8 text-center animate-in animate-in-delay-3">
        <p class="m-0 code-label"><span class="sym sym-comment">//</span> no posts in this category</p>
      </div>
    ) : (
      <div class="section-card border-0! bg-transparent! overflow-hidden animate-in animate-in-delay-3">
      <ul class="post-list terminal-list">
        {list.map((entry) => (
          <li>
            <PostCard
              title={entry.data.title}
              url={entry.data.url}
              excerpt={entry.data.excerpt}
              pubDate={entry.data.created_timestamp}
              categories={entry.data.categories}
              tags={entry.data.tags}
            />
          </li>
        ))}
      </ul>
      </div>
    )}
  </section>
</BlogLayout>
