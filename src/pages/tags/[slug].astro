---
import BlogLayout from '../../layouts/BlogLayout.astro'
import Banner from '../../components/Banner.astro'
import PostCard from '../../components/PostCard.astro'
import { getCollection } from 'astro:content'
import { getDerivedFromPosts } from '../../utils/derived-collections'

const { slug } = Astro.params
const posts = await getCollection('post', ({ data }) => data.published)
const { tags, postTags } = getDerivedFromPosts(posts)
const tag = tags.find((t) => t.url.replace(/^\/tags\//, '') === slug)
if (!tag) return Astro.redirect('/')
const postIds = new Set(postTags.filter((pt) => pt.tagId === tag.id).map((pt) => pt.postId))
const list = posts.filter((p) => postIds.has(p.id)).sort((a, b) => b.data.created_timestamp - a.data.created_timestamp)
---
<BlogLayout title={`标签: ${tag.title}`}>
  <Banner title={`标签: ${tag.title}`} subtitle={tag.description || `共 ${list.length} 篇`} />
  <div class="intro-bubble animate-in animate-in-delay-1">
    <p class="m-0 code-label">共 <strong>{list.length}</strong> 篇文章</p>
  </div>
  <section class="space-y-5">
    <h2 class="section-title animate-in animate-in-delay-2">{tag.title}</h2>
    {list.length === 0 ? (
      <div class="section-card p-8 text-center animate-in animate-in-delay-3">
        <p class="m-0 code-label">该标签下暂无文章</p>
      </div>
    ) : (
      <div class="section-card border-0! bg-transparent! overflow-hidden animate-in animate-in-delay-3">
      <ul class="post-list terminal-list">
        {list.map((entry) => (
          <li>
            <PostCard
              title={entry.data.title}
              url={entry.data.url}
              excerpt={entry.data.excerpt}
              pubDate={entry.data.created_timestamp}
              categories={entry.data.categories}
              tags={entry.data.tags}
            />
          </li>
        ))}
      </ul>
      </div>
    )}
  </section>
</BlogLayout>
