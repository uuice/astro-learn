---
import BlogLayout from '../layouts/BlogLayout.astro'
import Banner from '../components/Banner.astro'
import { getCollection } from 'astro:content'
import { getDerivedFromPosts } from '../utils/derived-collections'

const posts = await getCollection('post', ({ data }) => data.published)
const { categories, tags, postCategories, postTags } = getDerivedFromPosts(posts)
const categoryCounts = Object.fromEntries(categories.map((c) => [c.id, postCategories.filter((pc) => pc.categoryId === c.id).length]))
const tagCounts = Object.fromEntries(tags.map((t) => [t.id, postTags.filter((pt) => pt.tagId === t.id).length]))
const menu = (await getCollection('menu')).map((e) => ({ title: e.data.title, url: e.data.url, target: e.data.target }))
const [setting] = await getCollection('setting')
const authors = await getCollection('author')
const defaultAuthor = authors.find((a) => a.data.isDefault) ?? authors[0]
const siteName = setting?.data.siteSetting?.siteName ?? '博客'
const recordInfo = setting?.data.recordSettings ? { ...setting.data.recordSettings } : undefined
const links = await getCollection('link')
---
<BlogLayout
  title="友情链接"
  siteName={siteName}
  menu={menu}
  categories={categories}
  tags={tags}
  categoryCounts={categoryCounts}
  tagCounts={tagCounts}
  author={defaultAuthor ? { title: defaultAuthor.data.title, excerpt: defaultAuthor.data.excerpt, url: defaultAuthor.data.url } : undefined}
  recordInfo={recordInfo}
>
  <Banner title="友情链接" subtitle="交换链接、友链" />
  <div class="intro-bubble animate-in animate-in-delay-1">
    <p class="m-0 code-label">$ count: <strong style="color:var(--accent)">{links.length}</strong> links --top={links.length}</p>
    <p class="m-0 mt-1 code-label">[INFO] 点击链接在新窗口打开</p>
  </div>
  <section class="space-y-5 animate-in animate-in-delay-2">
    <h2 class="section-title"><span class="section-prompt">##</span> export 友链</h2>
    <p class="code-label mb-3">// {links.length} links</p>
    <ul class="post-list terminal-list">
      {links.map((entry) => (
        <li>
          <a
            href={entry.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="terminal-item block py-2 px-3 transition-colors hover:bg-(--page-bg)"
            style="font-family:var(--font-mono);font-size:var(--text-sm)"
          >
            <div class="terminal-export-line">### link <span class="export-name">{entry.data.title.replace(/\s+/g, '-').toLowerCase()}</span></div>
            <div class="terminal-meta-line">
              <span class="font-medium">{entry.data.title}</span>
              {entry.data.type && <span class="meta-from"> type="{entry.data.type}"</span>}
              <span class="meta-desc"> → {entry.data.url}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BlogLayout>
