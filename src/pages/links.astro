---
import BlogLayout from '../layouts/BlogLayout.astro'
import Banner from '../components/Banner.astro'
import { getCollection } from 'astro:content'
import { getDerivedFromPosts } from '../utils/derived-collections'

const posts = await getCollection('post', ({ data }) => data.published)
const { categories, tags, postCategories, postTags } = getDerivedFromPosts(posts)
const categoryCounts = Object.fromEntries(categories.map((c) => [c.id, postCategories.filter((pc) => pc.categoryId === c.id).length]))
const tagCounts = Object.fromEntries(tags.map((t) => [t.id, postTags.filter((pt) => pt.tagId === t.id).length]))
const menu = (await getCollection('menu')).map((e) => ({ title: e.data.title, url: e.data.url, target: e.data.target }))
const [setting] = await getCollection('setting')
const authors = await getCollection('author')
const defaultAuthor = authors.find((a) => a.data.isDefault) ?? authors[0]
const siteName = setting?.data.siteSetting?.siteName ?? '博客'
const recordInfo = setting?.data.recordSettings ? { ...setting.data.recordSettings } : undefined
const links = await getCollection('link')
---
<BlogLayout
  title="友情链接"
  siteName={siteName}
  menu={menu}
  categories={categories}
  tags={tags}
  categoryCounts={categoryCounts}
  tagCounts={tagCounts}
  author={defaultAuthor ? { title: defaultAuthor.data.title, excerpt: defaultAuthor.data.excerpt, url: defaultAuthor.data.url } : undefined}
  recordInfo={recordInfo}
>
  <Banner title="友情链接" subtitle="交换链接、友链" icon="🔗" />
  <div class="intro-bubble">
    <p class="m-0" style="color:var(--text-muted);font-size:var(--text-base)">共 <strong style="color:var(--accent)">{links.length}</strong> 个链接</p>
  </div>
  <section class="section-card p-6 md:p-8">
    <ul class="grid gap-4 sm:grid-cols-2">
      {links.map((entry) => (
        <li>
          <a
            href={entry.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="link-card-cute flex items-center gap-4 p-4 border-2 transition-all hover:scale-[1.02] group"
            style="border-radius:var(--radius);border-color:var(--card-border);background:var(--card-bg)"
          >
            <span class="w-12 h-12 rounded-2xl flex items-center justify-center text-2xl shrink-0" style="background:var(--card-border)">{entry.data.icon || '🔗'}</span>
            <div class="min-w-0 flex-1">
              <span class="font-medium block" style="color:var(--text);font-size:var(--text-base)">{entry.data.title}</span>
              {entry.data.type && <span class="inline-block mt-1 px-2 py-0.5 rounded-full" style="background:var(--card-border);color:var(--text-muted);font-size:var(--text-xs)">{entry.data.type}</span>}
            </div>
            <span class="opacity-0 group-hover:opacity-100 transition-opacity text-lg shrink-0" style="color:var(--accent)" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BlogLayout>
