---
import BlogLayout from '../layouts/BlogLayout.astro'
import Banner from '../components/Banner.astro'
import Comment from '../components/client/Comment.tsx'
import { getCollection } from 'astro:content'

const links = await getCollection('link')
---
<BlogLayout title="友情链接">
  <Banner title="友情链接" subtitle="交换链接、友链" />
  <div class="intro-bubble animate-in animate-in-delay-1">
    <p class="m-0 code-label">共 <strong>{links.length}</strong> 个链接</p>
  </div>
  <section class="space-y-5">
    <h2 class="section-title animate-in animate-in-delay-2">友链列表</h2>
    <p class="code-label mb-3">{links.length} 个链接</p>
    <div class="section-card border-0! bg-transparent! overflow-hidden animate-in animate-in-delay-3">
    <ul class="post-list terminal-list">
      {links.map((entry) => (
        <li>
          <a
            href={entry.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="terminal-item block py-2 px-3 transition-colors hover:bg-(--page-bg)"
            style="font-family:var(--font-mono);font-size:var(--text-sm)"
          >
            <div class="terminal-meta-line">
              <span class="font-medium">{entry.data.title}</span>
              {entry.data.type && <span class="meta-from"> type="{entry.data.type}"</span>}
              <span class="meta-desc"> → {entry.data.url}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
    </div>
  </section>
  <section class="mt-6">
    <Comment client:load postId="/links" />
  </section>
</BlogLayout>
