---
import BlogLayout from '../layouts/BlogLayout.astro'
import { getCollection } from 'astro:content'

interface Props {
  error: unknown
}

const { error } = Astro.props
const message = error instanceof Error ? error.message : 'Unknown error'
const menu = (await getCollection('menu')).map((e) => ({ title: e.data.title, url: e.data.url, target: e.data.target }))
---
<BlogLayout title="错误">
  <article class="section-card error-page px-4 sm:px-6 py-6 sm:py-8">
    <div class="error-page-intro">
      <p class="code-label">$ tail -f error.log</p>
      <p class="wrap-break-word">Error: {message}</p>
    </div>
    <h1 class="error-page-title">500 Server Error</h1>
    <p class="error-page-desc">服务器处理请求时出错了。</p>
    <p class="error-page-desc">可能是临时故障，请稍后重试或返回其他页面。</p>
    <div class="error-page-nav">
      <p class="code-label">$ ls /</p>
      <p class="error-page-nav-caption">可去的目录：</p>
      <ul class="error-page-nav-list">
        {menu.map((item) => (
          <li>
            <a href={item.url} target={item.target || '_self'}>{item.title}</a>
          </li>
        ))}
      </ul>
    </div>
    <p class="error-page-back">
      <a href="/">$ cd / ← 返回首页</a>
    </p>
  </article>
</BlogLayout>
