---
import BlogLayout from '../layouts/BlogLayout.astro'
import Banner from '../components/Banner.astro'
import PostCard from '../components/PostCard.astro'
import { getCollection } from 'astro:content'

const posts = await getCollection('post', ({ data }) => data.published)
const sorted = [...posts].sort((a, b) => b.data.created_timestamp - a.data.created_timestamp)
const byYearMonth = new Map<string, typeof sorted>()
for (const p of sorted) {
  const d = new Date(p.data.created_timestamp)
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`
  if (!byYearMonth.has(key)) byYearMonth.set(key, [])
  byYearMonth.get(key)!.push(p)
}
const groups = Array.from(byYearMonth.entries()).sort((a, b) => b[0].localeCompare(a[0]))
---
<BlogLayout title="归档">
  <Banner title="归档" subtitle="按时间查看文章" />
  <div class="intro-bubble animate-in animate-in-delay-1">
    <p class="m-0 code-label">$ count: <strong style="color:var(--accent)">{sorted.length}</strong> posts --top={sorted.length}</p>
    <p class="m-0 mt-1 code-label">[INFO] 按时间分组浏览</p>
  </div>
  <section class="space-y-8">
    {groups.map(([ym, list], i) => (
      <div class="section-card p-5 sm:p-6 animate-in archive-group" style={`animation-delay: ${0.1 + i * 0.05}s`}>
        <p class="code-label mb-1" style="font-size:var(--text-xs)">{ym}/index</p>
        <h2 class="section-title">
          <span class="section-prompt">##</span> export {ym}
        </h2>
        <p class="code-label mb-3">// {list.length} posts</p>
        <ul class="post-list terminal-list">
          {list.map((entry) => (
            <li>
              <PostCard
                title={entry.data.title}
                url={entry.data.url}
                excerpt={entry.data.excerpt}
                pubDate={entry.data.created_timestamp}
                categories={entry.data.categories}
                tags={entry.data.tags}
              />
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</BlogLayout>
