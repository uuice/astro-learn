<button id="dark-toggle" type="button" class="search-trigger px-2.5 py-1.5 rounded border transition-colors hover:bg-(--card-border)" style="border-color:var(--card-border);background:var(--card-bg);color:var(--text-muted);font-family:var(--font-mono);font-size:var(--text-sm)" aria-label="切换暗色模式">
  <span class="dark:hidden" aria-hidden="true">dark</span>
  <span class="hidden dark:inline" aria-hidden="true">light</span>
</button>
<script>
  (function () {
    var html = document.documentElement, key = 'theme', dark = 'dark'
  document.getElementById('dark-toggle')?.addEventListener('click', function () {
      html.classList.toggle(dark)
    localStorage.setItem(key, html.classList.contains(dark) ? dark : 'light')
  })
})()
</script>
