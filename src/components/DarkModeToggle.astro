<button
  id="dark-toggle"
  type="button"
  class="search-trigger inline-flex items-center justify-center min-h-9 min-w-9 shrink-0 rounded-md border px-1.5 py-1.5 transition-colors hover:bg-(--card-border)"
  style="border-color:var(--card-border);background:var(--card-bg);color:var(--text-muted)"
  aria-label="切换暗色模式"
  title="明暗"
>
  <span class="dark:hidden" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" /></svg>
  </span>
  <span class="hidden dark:inline" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4" /><path d="M12 2v2" /><path d="M12 20v2" /><path d="m4.93 4.93 1.41 1.41" /><path d="m17.66 17.66 1.41 1.41" /><path d="M2 12h2" /><path d="M20 12h2" /><path d="m6.34 17.66-1.41 1.41" /><path d="m19.07 4.93-1.41 1.41" /></svg>
  </span>
</button>
<script>
  (function () {
    var html = document.documentElement, key = 'theme', dark = 'dark'
    document.getElementById('dark-toggle')?.addEventListener('click', function () {
      html.classList.toggle(dark)
      localStorage.setItem(key, html.classList.contains(dark) ? dark : 'light')
    })
  })()
</script>
