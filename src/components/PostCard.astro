---
interface Props {
  title: string
  url: string
  excerpt?: string
  pubDate: Date | number
  categories?: string[]
  tags?: string[]
}
const { title, url, excerpt = '', pubDate, categories = [], tags = [] } = Astro.props
const date = typeof pubDate === 'number' ? new Date(pubDate) : pubDate
const dateStr = date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })
---
<article class="post-card-cute section-card p-5 group" style="border-left:4px solid var(--card-accent);border-radius:var(--radius)"
  <a href={url} class="block">
    <div class="flex items-start gap-3 mb-2">
      <span class="text-lg shrink-0 mt-0.5 opacity-80 group-hover:opacity-100" aria-hidden="true">📄</span>
      <div class="min-w-0 flex-1">
        <h2 class="font-semibold mb-1 group-hover:opacity-90 transition-opacity" style="font-size:var(--text-lg);color:var(--text)">{title}</h2>
        <time class="inline-block px-2 py-0.5 rounded-full text-xs" style="background:var(--card-border);color:var(--text-muted)">{dateStr}</time>
      </div>
    </div>
    {excerpt && (
      <p class="line-clamp-2 pl-8 mb-3" style="color:var(--text-muted);font-size:var(--text-sm)">{excerpt}</p>
    )}
    <div class="flex flex-wrap gap-2 pl-8">
      {categories.map((c) => (
        <span class="px-2.5 py-1 rounded-full" style="background:var(--card-border);color:var(--text);font-size:var(--text-xs)">{c}</span>
      ))}
      {tags.map((t) => (
        <span class="px-2.5 py-1 rounded-full" style="background:var(--accent-2);color:var(--card-bg);font-size:var(--text-xs)">{t}</span>
      ))}
    </div>
    <p class="mt-3 pl-8 text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity" style="color:var(--accent)">阅读更多 →</p>
  </a>
</article>
