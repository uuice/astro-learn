---
interface Props {
  title: string
  url: string
  excerpt?: string
  pubDate: Date | number
  categories?: string[]
  tags?: string[]
}
const { title, url, excerpt = '', pubDate, categories = [], tags = [] } = Astro.props
const date = typeof pubDate === 'number' ? new Date(pubDate) : pubDate
const dateStr = date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })
const slug = title.replace(/\s+/g, '-').replace(/[^\w\u4e00-\u9fa5-]/g, '').toLowerCase() || 'post'
const fromStr = categories.length ? ` from "${categories.join(', ')}"` : ''
---
<article class="post-card-cute section-card group" style="border-left:3px solid var(--card-accent);border-radius:var(--radius)">
  <div class="terminal-export-line">### export <span class="export-name">{slug}</span></div>
  <a href={url} class="post-card-link block transition-colors hover:text-(--accent)">
    <span class="post-card-link-prefix">{slug}.md</span> import <span class="post-card-link-title">{title}</span> // <span class="meta-from">{dateStr}{fromStr}</span>{excerpt && <><span class="meta-desc"> {excerpt}</span></>}
  </a>
</article>
