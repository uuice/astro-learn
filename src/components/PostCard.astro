---
interface Props {
  title: string
  url: string
  excerpt?: string
  pubDate: Date | number
  categories?: string[]
  tags?: string[]
}
const { title, url, excerpt = '', pubDate, categories = [], tags = [] } = Astro.props
const date = typeof pubDate === 'number' ? new Date(pubDate) : pubDate
const dateStr = date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })
---
<article class="post-card-cute section-card group" style="border-radius:var(--radius)">
  <a href={url} class="post-card-link block px-4 py-3 transition-colors hover:text-(--accent)">
    <p class="post-card-title-line m-0 mt-1 font-mono text-sm">{title}</p>
    <p class="post-card-meta-line m-0 mt-0.5 font-mono text-xs">
      发布于 {dateStr}
      {categories.length ? (
        <><span class="post-card-sep">·</span>分类：{categories.join(', ')}</>
      ) : null}
      {tags.length ? (
        <>
          <span class="post-card-sep">·</span>
          <span>标签：</span>{' '}
          {tags.map((tag, i) => (
            <span class={`chroma-tag chroma-tag--${i % 6}`}>{tag}</span>
          ))}
        </>
      ) : null}
    </p>
    {excerpt ? (
      <p class="post-card-excerpt-line m-0 mt-1 font-mono text-xs">{excerpt}</p>
    ) : null}
  </a>
</article>
