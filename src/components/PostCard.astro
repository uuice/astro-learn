---
interface Props {
  title: string
  url: string
  excerpt?: string
  pubDate: Date | number
  categories?: string[]
  tags?: string[]
}
const { title, url, excerpt = '', pubDate, categories = [], tags = [] } = Astro.props
const date = typeof pubDate === 'number' ? new Date(pubDate) : pubDate
---
<article class="section-card p-5 rounded-2xl shadow-sm hover:shadow-lg transition-all duration-200 border-l-4" style="border-left-color:var(--card-accent)">
  <h2 class="text-xl font-semibold mb-2">
    <a href={url} class="transition-opacity hover:opacity-80" style="color:var(--text)">{title}</a>
  </h2>
  {excerpt && <p class="text-sm mb-3 line-clamp-2" style="color:var(--text-muted)">{excerpt}</p>}
  <p class="text-xs mb-3" style="color:var(--text-muted)">{date.toLocaleDateString('zh-CN')}</p>
  <div class="flex flex-wrap gap-2">
    {categories.map((c) => (
      <span class="px-2.5 py-1 rounded-lg text-xs" style="background:var(--card-border);color:var(--text)">{c}</span>
    ))}
    {tags.map((t) => (
      <span class="px-2.5 py-1 rounded-lg text-xs" style="color:var(--accent-2)">{t}</span>
    ))}
  </div>
</article>
