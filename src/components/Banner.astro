---
interface Props { title?: string; subtitle?: string }
const { title = '', subtitle = '' } = Astro.props
---
<header class="rounded-2xl mb-8 overflow-hidden shadow-lg border-2 text-white py-14 md:py-20 px-6" style="border-color:var(--accent);background:linear-gradient(to bottom right, var(--banner-from), var(--banner-via), var(--banner-to))">
  <h1 class="text-3xl md:text-4xl font-bold text-center tracking-tight">{title}</h1>
  {subtitle && <p class="text-center mt-3 text-white/90 text-sm md:text-base max-w-2xl mx-auto leading-relaxed">{subtitle}</p>}
</header>
