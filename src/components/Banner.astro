---
interface Props { title?: string; subtitle?: string; icon?: string }
const { title = '', subtitle = '', icon = '' } = Astro.props
---
<header class="banner-hero mb-6 overflow-hidden border py-8 md:py-12 px-5 sm:px-6 rounded-lg animate-in" style="border-color:var(--card-border);background:linear-gradient(135deg, var(--banner-from), var(--banner-via));color:var(--text)">
  <h1 class="font-bold tracking-tight" style="font-size:var(--text-2xl);font-family:var(--font-mono);margin:0">
    # &gt; {title}
  </h1>
  {subtitle && <p class="mt-1.5 max-w-2xl leading-relaxed code-label" style="font-size:var(--text-sm)">{subtitle}</p>}
</header>
