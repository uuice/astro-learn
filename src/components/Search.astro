---
const baseUrl = import.meta.env.BASE_URL || '/'
---
<button type="button" id="search-open" class="p-2.5 rounded-full border-2 transition-all hover:scale-110" style="border-color:var(--card-border);background:var(--card-bg);color:var(--accent);box-shadow:var(--shadow)" aria-label="搜索">
  <span aria-hidden="true">🔍</span>
</button>
<div id="search-overlay" class="fixed inset-0 z-50 hidden" style="background:rgba(0,0,0,0.35)" aria-hidden="true">
  <div class="max-w-xl mx-auto mt-[15vh] mx-4 overflow-hidden section-card" style="border-radius:var(--radius)" role="dialog" aria-label="搜索文章">
    <div class="p-3 border-b" style="border-color:var(--card-border)">
      <input
        type="search"
        id="search-input"
        autocomplete="off"
        placeholder="全文搜索（支持中文）…"
        class="w-full px-4 py-2.5 outline-none"
        style="background:var(--page-bg);color:var(--text);font-size:var(--text-base);border:1px solid var(--card-border);border-radius:var(--radius-sm)"
      />
    </div>
    <div id="search-results" class="max-h-[50vh] overflow-y-auto p-2"></div>
    <p id="search-empty" class="hidden p-4 text-center" style="color:var(--text-muted);font-size:var(--text-sm)">输入关键词搜索</p>
    <p id="search-no-match" class="hidden p-4 text-center" style="color:var(--text-muted);font-size:var(--text-sm)">无匹配结果</p>
  </div>
</div>
<script define:vars={{ baseUrl }}>
  function initSearch() {
    const overlay = document.getElementById('search-overlay')
    const openBtn = document.getElementById('search-open')
    const input = document.getElementById('search-input')
    const resultsEl = document.getElementById('search-results')
    const emptyEl = document.getElementById('search-empty')
    const noMatchEl = document.getElementById('search-no-match')
    if (!overlay || !openBtn || !input || !resultsEl || !emptyEl || !noMatchEl) return

    let docs = null
    let flexIndex = null
    let searchFn = null

    function escapeHtml(s) {
      const div = document.createElement('div')
      div.textContent = s
      return div.innerHTML
    }

    function render(items) {
      resultsEl.innerHTML = ''
      emptyEl.classList.add('hidden')
      noMatchEl.classList.add('hidden')
      if (items.length === 0) {
        noMatchEl.classList.remove('hidden')
        return
      }
      items.forEach((item) => {
        if (!item || !item.url) return
        const a = document.createElement('a')
        a.href = item.url
        a.className = 'block p-3 rounded-xl hover:opacity-90 transition-opacity'
        a.style.background = 'var(--card-bg)'
        a.style.color = 'var(--text)'
        a.style.fontSize = 'var(--text-sm)'
        a.style.border = '1px solid var(--card-border)'
        a.style.borderRadius = 'var(--radius-sm)'
        a.style.marginBottom = '0.5rem'
        const desc = item.excerpt || (item.body ? item.body.slice(0, 120) + (item.body.length > 120 ? '…' : '') : '')
        a.innerHTML = '<span class="font-semibold" style="color:var(--text)">' + escapeHtml(item.title || '') + '</span>' +
          (desc ? '<p class="mt-1 opacity-80" style="color:var(--text-muted);font-size:var(--text-xs)">' + escapeHtml(desc) + '</p>' : '')
        resultsEl.appendChild(a)
      })
    }

    function doSearch(q) {
      const term = (q || '').trim()
      if (!term) {
        emptyEl.classList.remove('hidden')
        resultsEl.innerHTML = ''
        noMatchEl.classList.add('hidden')
        return
      }
      if (!docs || !searchFn) {
        resultsEl.innerHTML = ''
        emptyEl.classList.add('hidden')
        noMatchEl.classList.add('hidden')
        return
      }
      const matched = searchFn(term, 15)
      render(matched)
    }

    openBtn.addEventListener('click', async () => {
      overlay.classList.remove('hidden')
      overlay.setAttribute('aria-hidden', 'false')
      input.value = ''
      emptyEl.classList.remove('hidden')
      noMatchEl.classList.add('hidden')
      resultsEl.innerHTML = ''
      input.focus()

      if (!docs) {
        try {
          const path = (baseUrl || '/').replace(/\/?$/, '') + '/search-index.json'
          const res = await fetch(path)
          if (!res.ok) throw new Error('fetch failed')
          docs = await res.json()
          const { createSearchIndex, search } = await import('../scripts/search.js')
          flexIndex = createSearchIndex(docs)
          searchFn = (term, limit) => search(flexIndex, docs, term, limit)
        } catch (e) {
          const simpleSearch = (q, limit) => {
            const words = q.toLowerCase().split(/\s+/).filter(Boolean)
            return docs.filter((d) => {
              const t = [d.title || '', d.excerpt || '', d.body || '', (d.categories || []).join(' '), (d.tags || []).join(' ')].join(' ').toLowerCase()
              return words.every((w) => t.includes(w))
            }).slice(0, limit || 15)
          }
          searchFn = simpleSearch
        }
      }
      doSearch(input.value)
    })

    input.addEventListener('input', () => doSearch(input.value))
    input.addEventListener('keydown', (e) => { if (e.key === 'Escape') close() })
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close() })

    function close() {
      overlay.classList.add('hidden')
      overlay.setAttribute('aria-hidden', 'true')
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearch)
  } else {
    initSearch()
  }
</script>
