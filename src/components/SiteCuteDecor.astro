---
interface Props {
  variant?: 'blog' | 'admin'
}
const { variant = 'blog' } = Astro.props
const layerClass = variant === 'admin' ? 'site-cute-layer site-cute-layer--admin' : 'site-cute-layer'
---

<div class={layerClass} aria-hidden="true">
  <span class="cute-float-icon cute-float-icon--1">✦</span>
  <span class="cute-float-icon cute-float-icon--2">✧</span>
  <span class="cute-float-icon cute-float-icon--3">⋆</span>
  <span class="cute-float-icon cute-float-icon--4">✦</span>
  <span class="cute-float-icon cute-float-icon--5">★</span>
  <span class="cute-float-icon cute-float-icon--6">✧</span>
  <span class="cute-float-icon cute-float-icon--7">♡</span>
  <span class="cute-float-icon cute-float-icon--8">☆</span>
  <span class="cute-float-icon cute-float-icon--9">✿</span>
  <span class="cute-float-icon cute-float-icon--10">❀</span>
  <span class="cute-float-icon cute-float-icon--11">˖</span>
  <span class="cute-float-icon cute-float-icon--12">✧</span>
  <span class="cute-dot cute-dot--1" />
  <span class="cute-dot cute-dot--2" />
  <span class="cute-dot cute-dot--3" />
  <span class="cute-dot cute-dot--4" />
  <span class="cute-dot cute-dot--5" />
  <span class="cute-blob cute-blob--a" />
  <span class="cute-blob cute-blob--b" />
  {variant === 'blog' && <span class="cute-blob cute-blob--c" />}
</div>
