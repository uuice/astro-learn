---
import type { CATEGORY, TAG } from '../types'
interface Props {
  categories: CATEGORY[]
  tags: TAG[]
  categoryCounts?: Record<string, number>
  tagCounts?: Record<string, number>
  author?: { title: string; excerpt?: string; url: string }
}
const { categories, tags, categoryCounts = {}, tagCounts = {}, author } = Astro.props
---
<aside class="space-y-6">
  {categories.length > 0 && (
    <div class="section-card p-4 overflow-hidden" style="border-radius:var(--radius)">
      <h3 class="section-title">
        <span aria-hidden="true">📁</span> 分类
      </h3>
      <ul class="space-y-1">
        {categories.map((c) => {
          const count = categoryCounts[c.id] ?? 0
          return (
            <li>
              <a href={c.url} class="flex items-center justify-between gap-2 py-2 px-3 rounded-xl transition-all hover:opacity-90 group" style="color:var(--text);background:transparent;font-size:var(--text-sm)">
                <span class="truncate group-hover:opacity-100" style="color:var(--accent)">{c.title}</span>
                <span class="shrink-0 min-w-[1.25rem] h-5 px-1.5 rounded-full font-medium flex items-center justify-center" style="background:var(--card-border);color:var(--text-muted);font-size:var(--text-xs)">{count}</span>
              </a>
            </li>
          )
        })}
      </ul>
    </div>
  )}
  {tags.length > 0 && (
    <div class="section-card p-4 overflow-hidden" style="border-radius:var(--radius)">
      <h3 class="section-title" style="color:var(--accent-2)">
        <span aria-hidden="true">🏷️</span> 标签
      </h3>
      <ul class="flex flex-wrap gap-2">
        {tags.map((t) => {
          const count = tagCounts[t.id] ?? 0
          return (
            <li>
              <a href={t.url} class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full transition-all hover:scale-105 font-medium" style="background:var(--card-border);color:var(--text);font-size:var(--text-xs)">
                {t.title}
                <span class="opacity-70" style="font-size:var(--text-xs)">{count}</span>
              </a>
            </li>
          )
        })}
      </ul>
    </div>
  )}
  {author && (
    <div class="section-card p-4 overflow-hidden relative" style="border-radius:var(--radius);border:2px dashed var(--card-border)">
      <h3 class="section-title" style="color:var(--accent-3)">
        <span aria-hidden="true">👤</span> 作者
      </h3>
      <p class="font-medium mt-1" style="color:var(--text);font-size:var(--text-sm)">{author.title}</p>
      {author.excerpt && <p class="mt-1 line-clamp-2" style="color:var(--text-muted);font-size:var(--text-xs)">{author.excerpt}</p>}
      <a href={author.url} class="mt-3 inline-flex items-center gap-1 font-medium transition-all hover:opacity-80 rounded-full px-3 py-1.5" style="color:var(--accent);font-size:var(--text-xs);background:var(--card-border)">关于作者 →</a>
    </div>
  )}
</aside>
