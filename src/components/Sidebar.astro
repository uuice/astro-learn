---
import type { CATEGORY, TAG } from '../types'
import SidebarCountdown from './SidebarCountdown'
import { getCollection } from 'astro:content'

interface Props {
  categories: CATEGORY[]
  tags: TAG[]
  categoryCounts?: Record<string, number>
  tagCounts?: Record<string, number>
  author?: { title: string; excerpt?: string; url: string }
}
const { categories, tags, categoryCounts = {}, tagCounts = {}, author } = Astro.props
const [holidayEntry] = await getCollection('holiday')
const holidayData = holidayEntry ? { year: holidayEntry.data.year, holidays: holidayEntry.data.holidays } : null
---
<aside class="space-y-6">
  {categories.length > 0 && (
    <div class="section-card p-4 overflow-hidden" style="border-radius:var(--radius)">
      <h3 class="section-title">分类</h3>
      <ul class="terminal-list-sidebar">
        {categories.map((c, i) => {
          const count = categoryCounts[c.id] ?? 0
          return (
            <li>
              <a href={c.url}>
                <span>{c.title}</span>
                <span class={`sidebar-category-count chroma-tag--${i % 6}`}>{count}</span>
              </a>
            </li>
          )
        })}
      </ul>
    </div>
  )}
  {tags.length > 0 && (
    <div class="section-card p-4 overflow-hidden" style="border-radius:var(--radius)">
      <h3 class="section-title">标签</h3>
      <ul class="flex flex-wrap gap-1.5">
        {tags.map((t, i) => {
          const count = tagCounts[t.id] ?? 0
          return (
            <li>
              <a
                href={t.url}
                class={`sidebar-tag-pill inline-flex items-center gap-1 px-2 py-1 rounded font-medium chroma-tag chroma-tag--${i % 6}`}
                style="background:transparent;font-size:var(--text-xs);font-family:var(--font-mono)"
              >
                {t.title}<span class="opacity-70">({count})</span>
              </a>
            </li>
          )
        })}
      </ul>
    </div>
  )}
  {author && (
    <div class="section-card p-4 overflow-hidden" style="border-radius:var(--radius)">
      <h3 class="section-title">作者</h3>
      <p class="font-medium mt-1" style="color:var(--text);font-size:var(--text-sm)">{author.title}</p>
      {author.excerpt && <p class="mt-1 line-clamp-2" style="color:var(--text-muted);font-size:var(--text-xs)">{author.excerpt}</p>}
      <a href={author.url} class="mt-3 inline-flex items-center gap-1 font-medium rounded px-2 py-1 text-sm transition-colors hover:bg-(--card-border)" style="color:var(--accent);font-family:var(--font-mono)">查看详情 →</a>
    </div>
  )}
  {holidayData && (
    <SidebarCountdown client:load year={holidayData.year} holidays={holidayData.holidays} />
  )}
</aside>
