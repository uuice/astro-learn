---
import '../assets/styles/global.css'
import DarkModeToggle from '../components/DarkModeToggle.astro'
import Sidebar from '../components/Sidebar.astro'
import type { CATEGORY, TAG } from '../types'
interface RecordInfo {
  icpNumber?: string
  icpLink?: string
  policeNumber?: string
  policeLink?: string
  showRecord?: boolean
}
interface Props {
  title: string
  siteName: string
  menu: { title: string; url: string; target?: string }[]
  categories: CATEGORY[]
  tags: TAG[]
  categoryCounts?: Record<string, number>
  tagCounts?: Record<string, number>
  author?: { title: string; excerpt?: string; url: string }
  recordInfo?: RecordInfo
}
const { title, siteName, menu, categories, tags, categoryCounts = {}, tagCounts = {}, author, recordInfo } = Astro.props
const showRecord = recordInfo?.showRecord !== false && (recordInfo?.icpNumber || recordInfo?.policeNumber)
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} - {siteName}</title>
    <script is:inline>
      (function(){var d=document.documentElement,k='theme',v=localStorage.getItem(k);if(v==='dark'||(!v&&window.matchMedia('(prefers-color-scheme:dark)').matches))d.classList.add('dark');else d.classList.remove('dark');})();
    </script>
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <div class="min-h-screen flex flex-col">
      <header class="sticky top-0 z-30 flex flex-col border-b-2 shadow-sm" style="background:var(--header-bg);border-color:var(--border)">
        <div class="max-w-6xl mx-auto w-full px-4 py-3 flex items-center justify-between gap-4">
          <a href="/" class="font-bold text-lg" style="color:var(--text)">{siteName}</a>
          <div class="hidden lg:flex items-center gap-6">
            {menu.map((item) => (
              <a href={item.url} target={item.target || '_self'} class="text-sm font-medium transition-colors hover:opacity-80" style="color:var(--accent)">{item.title}</a>
            ))}
          </div>
          <div class="flex items-center gap-2 ml-auto">
            <DarkModeToggle />
          </div>
        </div>
        <div class="lg:hidden border-t px-4 py-2.5 overflow-x-auto" style="border-color:var(--card-border)">
          <nav class="flex gap-4 min-w-max pb-1" aria-label="主导航">
            {menu.map((item) => (
              <a href={item.url} target={item.target || '_self'} class="text-sm font-medium whitespace-nowrap transition-opacity hover:opacity-80" style="color:var(--accent)">{item.title}</a>
            ))}
          </nav>
        </div>
      </header>

      <div class="max-w-6xl mx-auto w-full px-4 py-6 md:py-8 flex-1 flex flex-col lg:flex-row gap-8">
        <main class="flex-1 min-w-0">
          <slot />
        </main>
        <div class="w-64 shrink-0 hidden lg:block">
          <div class="sticky top-24">
            <Sidebar categories={categories} tags={tags} categoryCounts={categoryCounts} tagCounts={tagCounts} author={author} />
          </div>
        </div>
        <div class="lg:hidden mt-4 pt-8 border-t-2" style="border-color:var(--card-border)">
          <Sidebar categories={categories} tags={tags} categoryCounts={categoryCounts} tagCounts={tagCounts} author={author} />
        </div>
      </div>

      <footer class="py-8 mt-auto border-t-2" style="background:var(--footer-bg);border-color:var(--border)">
        <div class="max-w-6xl mx-auto px-4 text-center text-sm space-y-1" style="color:var(--text-muted)">
          <p class="font-medium" style="color:var(--text)">© {new Date().getFullYear()} {siteName}</p>
          <p>记录与分享</p>
          {showRecord && (
            <p class="pt-2 text-xs">
              {recordInfo?.icpNumber && (
                <a href={recordInfo.icpLink || 'https://beian.miit.gov.cn/'} target="_blank" rel="noopener noreferrer" class="hover:opacity-80" style="color:var(--text-muted)">{recordInfo.icpNumber}</a>
              )}
              {recordInfo?.policeNumber && (
                <>
                  {recordInfo?.icpNumber && ' · '}
                  <a href={recordInfo.policeLink || '#'} target="_blank" rel="noopener noreferrer" class="hover:opacity-80" style="color:var(--text-muted)">{recordInfo.policeNumber}</a>
                </>
              )}
            </p>
          )}
        </div>
      </footer>
    </div>
  </body>
</html>
