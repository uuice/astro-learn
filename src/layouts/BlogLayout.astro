---
import '../assets/styles/global.css'
import DarkModeToggle from '../components/DarkModeToggle.astro'
import Search from '../components/Search.astro'
import ThemeColor from '../components/ThemeColor.astro'
import Sidebar from '../components/Sidebar.astro'
import { getCollection } from 'astro:content'
import { getDerivedFromPosts } from '../utils/derived-collections'
interface Props {
  title: string
}
const { title } = Astro.props
const posts = await getCollection('post', ({ data }) => data.published)
const { categories, tags, postCategories, postTags } = getDerivedFromPosts(posts)
const categoryCounts = Object.fromEntries(categories.map((c) => [c.id, postCategories.filter((pc) => pc.categoryId === c.id).length]))
const tagCounts = Object.fromEntries(tags.map((t) => [t.id, postTags.filter((pt) => pt.tagId === t.id).length]))
const menu = (await getCollection('menu')).map((e) => ({ title: e.data.title, url: e.data.url, target: e.data.target }))
const [setting] = await getCollection('setting')
const authors = await getCollection('author')
const defaultAuthor = authors.find((a) => a.data.isDefault) ?? authors[0]
const siteName = setting?.data.siteSetting?.siteName ?? '博客'
const recordInfo = setting?.data.recordSettings ? { ...setting.data.recordSettings } : undefined
const showRecord = recordInfo?.showRecord !== false && (recordInfo?.icpNumber || recordInfo?.policeNumber)
const author = defaultAuthor ? { title: defaultAuthor.data.title, excerpt: defaultAuthor.data.excerpt, url: defaultAuthor.data.url } : undefined
const documentTitle = title === siteName ? siteName : `${title} · ${siteName}`
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{documentTitle}</title>
    <script is:inline>
      (function(){var d=document.documentElement,k='theme',v=localStorage.getItem(k);if(v==='dark'||(!v&&window.matchMedia('(prefers-color-scheme:dark)').matches))d.classList.add('dark');else d.classList.remove('dark');var h=localStorage.getItem('themeHue');if(h!==null){var n=parseInt(h,10);if(!isNaN(n)&&n>=0&&n<=360)d.style.setProperty('--hue',String(n))}})()

    </script>
  </head>
  <body class="blog-skin min-h-screen flex flex-col antialiased">
    <!-- 顶部滚动进度条：animation-timeline: scroll(root block) -->
    <div
      class="scroll-progress-bar fixed top-0 left-0 right-0 z-50 h-0.5 origin-left"
      role="presentation"
      aria-hidden="true"
      style="background: var(--accent); animation: scale-progress linear; animation-duration: 1ms; animation-timeline: scroll(root block); animation-range: 0% 100%;"
    />
    <!-- <BackgroundGradient client:load /> -->
    <div class="min-h-screen flex flex-col">
      <header class="sticky top-0 z-30 flex flex-col border-b" style="background:var(--header-bg);border-color:var(--border)">
        <div class="max-w-6xl mx-auto w-full px-4 sm:px-6 py-3 flex items-center justify-between gap-4">
          <a href="/" class="header-brand font-semibold transition-opacity hover:opacity-80 flex items-center gap-1.5" style="font-size:var(--text-sm);font-family:var(--font-mono)">
            <span class="code-label sym sym-prompt">$</span>
            <span class="header-brand-name">{siteName}</span>
          </a>
          <nav class="hidden lg:flex items-center gap-5" aria-label="主导航">
            {menu.map((item) => (
              <a href={item.url} target={item.target || '_self'} class="nav-link-cute py-1 flex items-center gap-1.5" style="color:var(--text-muted);font-size:var(--text-xs);font-family:var(--font-mono)">
                <span class="nav-symbol sym sym-chevron">›</span>
                {item.title}
              </a>
            ))}
          </nav>
          <div class="flex items-center gap-1 sm:gap-2 ml-auto shrink-0">
            <button
              type="button"
              id="mobile-nav-open"
              class="search-trigger lg:hidden inline-flex items-center justify-center min-h-9 min-w-9 shrink-0 rounded-md border px-1.5 py-1.5 transition-colors hover:bg-(--card-border)"
              style="border-color:var(--card-border);background:var(--card-bg);color:var(--text-muted)"
              aria-expanded="false"
              aria-controls="mobile-nav-panel"
              aria-label="打开菜单"
              title="菜单"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" x2="20" y1="6" y2="6" /><line x1="4" x2="20" y1="12" y2="12" /><line x1="4" x2="20" y1="18" y2="18" /></svg>
            </button>
            <Search />
            <ThemeColor />
            <DarkModeToggle />
          </div>
        </div>
      </header>

      <!-- 移动端主导航抽屉（lg 以下） -->
      <div
        id="mobile-nav-root"
        class="mobile-nav-root lg:hidden fixed inset-0 z-40 pointer-events-none"
        aria-hidden="true"
        data-open="false"
      >
        <button
          type="button"
          id="mobile-nav-backdrop"
          class="mobile-nav-backdrop absolute inset-0 bg-black/40 opacity-0 transition-opacity"
          style="transition-duration:var(--duration-normal)"
          aria-label="关闭菜单"
          tabindex="-1"
        />
        <aside
          id="mobile-nav-panel"
          class="mobile-nav-panel absolute top-0 right-0 flex h-full w-[min(20rem,88vw)] max-w-full flex-col border-l shadow-lg translate-x-full transition-transform ease-out"
          style="background:var(--header-bg);border-color:var(--border);box-shadow:var(--shadow);transition-duration:var(--duration-normal)"
          aria-label="主导航"
        >
          <div class="flex items-center justify-between gap-3 border-b px-4 py-3" style="border-color:var(--border)">
            <p class="m-0 flex items-center gap-1.5 flex-wrap" style="font-size:var(--text-xs);font-family:var(--font-mono);color:var(--text-muted)">
              <span class="code-label sym sym-prompt">$</span>
              <span class="sym sym-keyword">cd</span>
              <span class="sym terminal-cwd">nav</span>
            </p>
            <button
              type="button"
              id="mobile-nav-close"
              class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md border transition-colors hover:opacity-90"
              style="font-size:var(--text-lg);line-height:1;color:var(--text);border-color:var(--card-border);background:var(--card-bg)"
              aria-label="关闭菜单"
            >
              ×
            </button>
          </div>
          <nav class="flex flex-1 flex-col gap-0.5 overflow-y-auto p-3" aria-label="主导航">
            {menu.map((item) => (
              <a
                href={item.url}
                target={item.target || '_self'}
                class="nav-link-cute flex items-center gap-2 rounded-md px-3 py-3"
                style="color:var(--text-muted);font-size:var(--text-sm);font-family:var(--font-mono)"
                data-mobile-nav-link
              >
                <span class="nav-symbol shrink-0 sym sym-chevron">›</span>
                {item.title}
              </a>
            ))}
          </nav>
        </aside>
      </div>

      <div class="max-w-6xl mx-auto w-full px-4 sm:px-6 py-6 md:py-8 flex-1 flex flex-col lg:flex-row gap-8 lg:gap-10">
        <main class="flex-1 min-w-0 page-main" id="pjax-main">
          <slot />
        </main>
        <div class="w-64 shrink-0 hidden lg:block">
          <div class="sticky top-24">
            <Sidebar categories={categories} tags={tags} categoryCounts={categoryCounts} tagCounts={tagCounts} author={author} />
          </div>
        </div>
        <div class="lg:hidden mt-6 pt-6 border-t" style="border-color:var(--card-border)">
          <Sidebar categories={categories} tags={tags} categoryCounts={categoryCounts} tagCounts={tagCounts} author={author} />
        </div>
      </div>

      <footer class="py-8 mt-auto border-t" style="background:var(--footer-bg);border-color:var(--border)">
        <div class="max-w-6xl mx-auto px-4 sm:px-6" style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-muted)">
          <p class="mb-2.5 flex flex-wrap items-center gap-x-2 gap-y-1">
            <span class="inline-flex flex-wrap items-center gap-1 font-mono text-xs" style="color:var(--text-muted)">
              <span class="code-label sym sym-prompt">$</span>
              <span class="sym sym-keyword">cd</span>
              <span class="sym terminal-cwd">top</span>
            </span>
            <a href="#" id="footer-back-to-top" class="transition-colors hover:opacity-80" style="color:var(--accent)">返回顶部</a>
          </p>
          <p class="font-medium" style="color:var(--text)">© {new Date().getFullYear()} {siteName}</p>
          <p class="pt-1" style="font-size:var(--text-xs);color:var(--text-muted)">网站基于 <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:opacity-80" style="color:var(--accent)">Astro</a> 构建 · <a href="/rss" target="_blank" rel="noopener noreferrer" class="hover:opacity-80" style="color:var(--accent)">RSS</a> · <a href="/sitemap" target="_blank" rel="noopener noreferrer" class="hover:opacity-80" style="color:var(--accent)">Sitemap</a></p>
          {showRecord && (
            <p class="pt-1.5" style="font-size:var(--text-xs)">
              {recordInfo?.icpNumber && (
                <a href={recordInfo.icpLink || 'https://beian.miit.gov.cn/'} target="_blank" rel="noopener noreferrer" class="hover:opacity-80" style="color:var(--text-muted)">{recordInfo.icpNumber}</a>
              )}
              {recordInfo?.policeNumber && (
                <>
                  {recordInfo?.icpNumber && ' · '}
                  <a href={recordInfo.policeLink || '#'} target="_blank" rel="noopener noreferrer" class="hover:opacity-80" style="color:var(--text-muted)">{recordInfo.policeNumber}</a>
                </>
              )}
            </p>
          )}
        </div>
      </footer>

      <a href="#" id="back-to-top" class="back-to-top fixed right-6 bottom-6 z-40 opacity-0 pointer-events-none transition-opacity duration-200 inline-flex items-center gap-1" style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text);background:var(--card-bg);border:1px solid var(--card-border);padding:0.4rem 0.65rem;border-radius:var(--radius-sm);box-shadow:var(--shadow)" aria-label="返回顶部"><span class="code-label sym sym-prompt">$</span><span class="sym sym-keyword">cd</span><span class="sym terminal-cwd">top</span></a>
    </div>
    <script src="../scripts/pjax.ts" />
    <style is:global>
      .page-main.pjax-transitioning { opacity: 0.7; transition: opacity 0.15s ease-out; }
      @keyframes scale-progress {
        from { transform: scaleX(0); }
        to { transform: scaleX(1); }
      }
      #mobile-nav-root[data-open='true'] {
        pointer-events: auto;
      }
      #mobile-nav-root[data-open='true'] .mobile-nav-backdrop {
        opacity: 1;
      }
      /* Tailwind v4 用 translate 属性而非 transform，须重置 --tw-translate-x */
      #mobile-nav-root[data-open='true'] .mobile-nav-panel {
        --tw-translate-x: 0;
      }
      @media (prefers-reduced-motion: reduce) {
        #mobile-nav-backdrop,
        #mobile-nav-panel {
          transition: none !important;
        }
      }
    </style>
    <script is:inline>
      (function(){
        var topBtn = document.getElementById('back-to-top')
        var footerLink = document.getElementById('footer-back-to-top')
        function scrollToTop(e) {
          if (e) e.preventDefault()
          window.scrollTo({ top: 0, behavior: 'smooth' })
        }
        function onScroll() {
          if (!topBtn) return
          if (window.scrollY > 300) {
            topBtn.classList.remove('opacity-0', 'pointer-events-none')
            topBtn.classList.add('opacity-100')
          } else {
            topBtn.classList.add('opacity-0', 'pointer-events-none')
            topBtn.classList.remove('opacity-100')
          }
        }
        if (topBtn) {
          topBtn.addEventListener('click', scrollToTop)
          window.addEventListener('scroll', onScroll, { passive: true })
        }
        if (footerLink) footerLink.addEventListener('click', scrollToTop)
      })()
    </script>
    <script is:inline>
      (function () {
        var root = document.getElementById('mobile-nav-root')
        var openBtn = document.getElementById('mobile-nav-open')
        var closeBtn = document.getElementById('mobile-nav-close')
        var backdrop = document.getElementById('mobile-nav-backdrop')
        if (!root || !openBtn || !closeBtn || !backdrop) return

        function setOpen(open) {
          root.setAttribute('data-open', open ? 'true' : 'false')
          root.setAttribute('aria-hidden', open ? 'false' : 'true')
          openBtn.setAttribute('aria-expanded', open ? 'true' : 'false')
          document.body.style.overflow = open ? 'hidden' : ''
        }
        function openNav() {
          setOpen(true)
        }
        function closeNav() {
          setOpen(false)
        }

        openBtn.addEventListener('click', function (e) {
          e.stopPropagation()
          openNav()
        })
        closeBtn.addEventListener('click', closeNav)
        backdrop.addEventListener('click', closeNav)
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && root.getAttribute('data-open') === 'true') closeNav()
        })
        window.addEventListener('pjax:complete', closeNav)
        root.querySelectorAll('[data-mobile-nav-link]').forEach(function (a) {
          a.addEventListener('click', closeNav)
        })
      })()
    </script>
  </body>
</html>
