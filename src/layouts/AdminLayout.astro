---
import '../assets/styles/global.css'
import SiteCuteDecor from '../components/SiteCuteDecor.astro'
import ThemeColor from '../components/ThemeColor.astro'
import DarkModeToggle from '../components/DarkModeToggle.astro'
import AdminLayoutReact from './AdminLayout.tsx'
import { getCollection } from 'astro:content'
import { getAdminNav } from '../lib/admin-site-config-db'

export const prerender = false

interface Props {
  title: string
}

const { title } = Astro.props
const [setting] = await getCollection('setting')
const siteName = setting?.data.siteSetting?.siteName ?? '博客'
const adminNav = await getAdminNav()
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · 管理</title>
    <script is:inline>
      (function(){var d=document.documentElement,k='theme',v=localStorage.getItem(k);if(v==='dark'||(!v&&window.matchMedia('(prefers-color-scheme:dark)').matches))d.classList.add('dark');else d.classList.remove('dark');var h=localStorage.getItem('themeHue');if(h!==null){var n=parseInt(h,10);if(!isNaN(n)&&n>=0&&n<=360)d.style.setProperty('--hue',String(n))}})()
    </script>
  </head>
  <body class="admin-skin min-h-screen flex flex-col antialiased">
    <SiteCuteDecor variant="admin" />
    <AdminLayoutReact client:load siteName={siteName} navItems={adminNav}>
      <Fragment slot="controls">
        <ThemeColor />
        <DarkModeToggle />
      </Fragment>
      <slot />
    </AdminLayoutReact>
  </body>
</html>
