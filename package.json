    "pm2:delete:bun": "pm2 delete astro-blog-bun",
    "pack": "tar -czvf astro-blog-release-$(date +%Y-%m-%d-%H%M%S).tar.gz dist server.mjs package.json pnpm-lock.yaml ecosystem.config.cjs",
    "pack:build": "pnpm build && pnpm run pack",
    "astro": "astro",
